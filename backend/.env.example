# ══════════════════════════════════════════════════════════════════
# .env.example — WhatsApp SaaS Platform
# انسخ هذا الملف إلى .env وأضف قيمك الحقيقية
# ══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# [مطلوب] قاعدة البيانات
# Railway: Variables → DATABASE_URL (مُضاف تلقائياً عند إنشاء PostgreSQL plugin)
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/whatsapp_saas
DATABASE_SSL=true
DB_POOL_MAX=5

# ─────────────────────────────────────────────────────────────────
# [مطلوب] Redis
# Railway: Variables → REDIS_URL (مُضاف تلقائياً عند إنشاء Redis plugin)
# أو Upstash: https://upstash.com (مجاني)
# ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://default:password@localhost:6379

# ─────────────────────────────────────────────────────────────────
# [مطلوب] JWT
# أنشئ مفاتيح عشوائية قوية:
#   openssl rand -hex 64
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_64_output_here
JWT_REFRESH_SECRET=CHANGE_ME_use_openssl_rand_hex_64_output_here_different
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES=7d

# ─────────────────────────────────────────────────────────────────
# [مطلوب] Admin الأولي
# ─────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_password_here

# ─────────────────────────────────────────────────────────────────
# [اختياري] PORT
# ⚠️  على Railway: لا تُعيِّن هذا — Railway يُعيِّنه تلقائياً
# للتطوير المحلي فقط:
# ─────────────────────────────────────────────────────────────────
# PORT=5000

# ─────────────────────────────────────────────────────────────────
# [اختياري] البيئة
# ─────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────
# [اختياري] CORS
# أضف domains مفصولة بفاصلة (اتركه فارغاً للسماح بالكل):
# CORS_ORIGINS=https://your-app.railway.app,https://your-domain.com
# ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=

# ─────────────────────────────────────────────────────────────────
# [اختياري] Anti-Ban WhatsApp
# ─────────────────────────────────────────────────────────────────
MAX_RECONNECT_ATTEMPTS=10
MAX_MSG_PER_HOUR=200
MSG_MIN_DELAY_MS=2000
MSG_MAX_DELAY_MS=8000
WARMUP_DAYS=7
WARMUP_LIMIT=30

# ════════════════════════════════════════════════════════
# Phase 5 — Security Hardening
# ════════════════════════════════════════════════════════

# [FIX-17] AES-256-GCM Encryption Key — 64 hex chars
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=your_64_hex_chars_here_replace_me_in_production

# [FIX-14] CSRF — disable in dev only (NEVER in production)
# DISABLE_CSRF=true

# [FIX-15] Rate Limiting — disable in dev only
# DISABLE_RATE_LIMIT=true

# [FIX-13] JWT Refresh Secret (مختلف عن JWT_SECRET)
# JWT_REFRESH_SECRET=another_strong_secret_here
